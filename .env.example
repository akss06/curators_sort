# Spotify App credentials — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Must match the Redirect URI added in your Spotify app settings exactly
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/oauth/callback

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Frontend origin — change if you deploy the frontend elsewhere
# FRONTEND_URL=http://localhost:5173
